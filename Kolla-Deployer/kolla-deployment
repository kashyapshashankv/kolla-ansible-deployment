### Once Deps are installed Update below file

kolla/share/kolla-ansible/ansible/roles/nova-cell/handlers/main.yml

- name: Create libvirt SASL user
  become: true
  shell:
    cmd: >
      set -o pipefail &&
      echo {{ libvirt_sasl_password }} |
      {{ kolla_container_engine }} exec -i nova_libvirt
      saslpasswd2 -c -p -u $(hostname -s) -a libvirt {{ libvirt_sasl_authname }} &&
      echo {{ libvirt_sasl_password }} |
      {{ kolla_container_engine }} exec -i nova_libvirt
      saslpasswd2 -c -p -u $(hostname -f) -a libvirt {{ libvirt_sasl_authname }}
    executable: /bin/bash
  changed_when: true
  no_log: true


##### Prepare for Kolla-ansible
### As Non Root User execute

python3 -m venv kolla
source kolla/bin/activate


#### Export any Proxy if Required ######
export https_proxy=http://172.30.19.16:3128

pip install -U pip
### 2024.2 is openstack version
pip install git+https://github.com/openstack/kolla-ansible@stable/2025.1

sudo mkdir -p /etc/kolla
sudo chown $USER:$USER /etc/kolla


#### Update kolla/share/kolla-ansible/requirements.yml file to github.com if opendev.org is blocked

kolla-ansible install-deps

### Once Deps are installed Update below file

kolla/share/kolla-ansible/ansible/roles/nova-cell/handlers/main.yml

- name: Create libvirt SASL user
  become: true
  shell:
    cmd: >
      set -o pipefail &&
      echo {{ libvirt_sasl_password }} |
      {{ kolla_container_engine }} exec -i nova_libvirt
      saslpasswd2 -c -p -u $(hostname -s) -a libvirt {{ libvirt_sasl_authname }} &&
      echo {{ libvirt_sasl_password }} |
      {{ kolla_container_engine }} exec -i nova_libvirt
      saslpasswd2 -c -p -u $(hostname -f) -a libvirt {{ libvirt_sasl_authname }}
    executable: /bin/bash
  changed_when: true
  no_log: true

##### Create file ansible.cfg
tee ansible.cfg<<EOF
[defaults]
host_key_checking=False
pipelining=True
forks=100
EOF



